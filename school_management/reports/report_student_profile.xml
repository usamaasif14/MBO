<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_student_profile_doc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center mt-4 mb-4">Student Profile</h2>
                        <div class="row">
                            <div class="col-8">
                                <table class="table table-borderless table-sm">
                                    <tr>
                                        <td style="width: 30%"><strong>Name:</strong></td>
                                        <td><span t-field="o.name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Roll No:</strong></td>
                                        <td><span t-field="o.roll_number"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Admission No:</strong></td>
                                        <td><span t-field="o.admission_number"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Class:</strong></td>
                                        <td><span t-field="o.class_id.name"/> <t t-if="o.section_id">- <span t-field="o.section_id.name"/></t></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Father Name:</strong></td>
                                        <td><span t-field="o.father_name"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Mobile:</strong></td>
                                        <td><span t-field="o.mobile"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Address:</strong></td>
                                        <td><span t-field="o.address"/>, <span t-field="o.city"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-4 text-end">
                                <t t-if="o.image">
                                    <img t-att-src="'data:image/png;base64,%s' % to_text(o.image)" style="max-height: 150px; max-width: 150px; border: 1px solid #ccc; padding: 5px;"/>
                                </t>
                            </div>
                        </div>

                        <h4 class="mt-4 mb-2 border-bottom pb-2">Academic Information</h4>
                        <table class="table table-bordered table-sm">
                            <tr>
                                <th>Academic Year</th>
                                <td><span t-field="o.academic_year"/></td>
                                <th>Admission Date</th>
                                <td><span t-field="o.admission_date"/></td>
                            </tr>
                            <tr>
                                <th>Previous School</th>
                                <td><span t-field="o.previous_school"/></td>
                                <th>Status</th>
                                <td><span t-field="o.state"/></td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
