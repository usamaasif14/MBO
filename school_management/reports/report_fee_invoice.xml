<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_fee_invoice_doc">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-size: 13px;">
                        <h3 class="text-center mb-3 border-bottom pb-2">Fee Invoice / Receipt</h3>
                        
                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Invoice No:</strong> <span t-field="o.name"/><br/>
                                <strong>Date:</strong> <span t-field="o.date"/><br/>
                                <strong>Due Date:</strong> <span t-field="o.due_date"/><br/>
                                <strong>Fee Month:</strong> <span t-field="o.fee_month"/> <span t-field="o.fee_year"/>
                            </div>
                            <div class="col-6 text-end">
                                <strong>Student:</strong> <span t-field="o.student_id.name"/><br/>
                                <strong>Roll No:</strong> <span t-field="o.roll_number"/><br/>
                                <strong>Class:</strong> <span t-field="o.class_id.name"/> <t t-if="o.section_id">- <span t-field="o.section_id.name"/></t><br/>
                                <strong>Status:</strong> <span t-field="o.state"/>
                            </div>
                        </div>

                        <table class="table table-sm table-bordered mt-3">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.invoice_line_ids" t-as="line">
                                    <tr>
                                        <td><span t-esc="line_index + 1"/></td>
                                        <td><span t-field="line.name"/></td>
                                        <td class="text-end"><span t-field="line.amount" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div class="row">
                            <div class="col-6 mt-3">
                                <t t-if="o.notes">
                                    <strong>Notes:</strong>
                                    <p><span t-field="o.notes"/></p>
                                </t>
                                <t t-if="o.payment_ids">
                                    <strong>Payment History:</strong>
                                    <table class="table table-sm table-borderless text-muted" style="font-size: 11px;">
                                        <t t-foreach="o.payment_ids" t-as="pay">
                                            <tr>
                                                <td><span t-field="pay.date"/></td>
                                                <td><span t-field="pay.name"/></td>
                                                <td><span t-field="pay.payment_method"/></td>
                                                <td><span t-field="pay.amount" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/></td>
                                            </tr>
                                        </t>
                                    </table>
                                </t>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td class="text-end"><strong>Gross Amount:</strong></td>
                                        <td class="text-end" style="width: 30%;">
                                            <span t-esc="sum(l.amount for l in o.invoice_line_ids)" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr t-if="o.concession_amount > 0">
                                        <td class="text-end text-danger"><strong>Discount/Concession:</strong></td>
                                        <td class="text-end text-danger">
                                            <span>- <span t-field="o.concession_amount" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/></span>
                                        </td>
                                    </tr>
                                    <tr t-if="o.late_fee > 0">
                                        <td class="text-end"><strong>Late Fee:</strong></td>
                                        <td class="text-end">
                                            <span t-field="o.late_fee" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/>
                                        </td>
                                    </tr>
                                    <tr class="border-top">
                                        <td class="text-end"><strong>Total Invoice Amount:</strong></td>
                                        <td class="text-end"><strong><span t-field="o.amount_total" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/></strong></td>
                                    </tr>
                                    <tr>
                                        <td class="text-end text-success"><strong>Paid Amount:</strong></td>
                                        <td class="text-end text-success"><strong><span t-field="o.amount_paid" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/></strong></td>
                                    </tr>
                                    <tr class="border-top bg-light">
                                        <td class="text-end"><strong>Current Balance Due:</strong></td>
                                        <td class="text-end"><strong><span t-field="o.amount_residual" t-options='{"widget": "monetary", "display_currency": user.company_id.currency_id}'/></strong></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        
                        <div class="row mt-5">
                            <div class="col-4 text-center">
                                _______________________<br/>
                                <strong>Cashier / Accountant</strong>
                            </div>
                            <div class="col-4 offset-4 text-center">
                                _______________________<br/>
                                <strong>Authorized Signature</strong>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
