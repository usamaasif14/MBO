<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- School Management Category -->
        <record id="module_school_management" model="ir.module.category">
            <field name="name">School Management</field>
            <field name="sequence">50</field>
        </record>

        <record id="school_groups_privilege" model="res.groups.privilege">
            <field name="name">School Management</field>
            <field name="category_id" ref="module_school_management"/>
        </record>

        <!-- Groups -->
        <record id="group_school_admin" model="res.groups">
            <field name="name">School Admin</field>
            <field name="privilege_id" ref="school_groups_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_school_teacher" model="res.groups">
            <field name="name">School Teacher</field>
            <field name="privilege_id" ref="school_groups_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_school_accountant" model="res.groups">
            <field name="name">School Accountant</field>
            <field name="privilege_id" ref="school_groups_privilege"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_school_principal" model="res.groups">
            <field name="name">School Principal</field>
            <field name="privilege_id" ref="school_groups_privilege"/>
            <field name="implied_ids" eval="[(4, ref('school_management.group_school_admin'))]"/>
        </record>

        <!-- Grant Administrator full school management access automatically -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('school_management.group_school_admin'))]"/>
        </record>
    </data>
</odoo>
