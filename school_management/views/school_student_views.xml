<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Student Form -->
        <record id="view_school_student_form" model="ir.ui.view">
            <field name="name">school.student.form</field>
            <field name="model">school.student</field>
            <field name="arch" type="xml">
                <form string="Student">
                    <header>
                        <button name="action_enroll" type="object" string="Enroll"
                                invisible="state != 'draft'" class="btn-primary"/>
                        <button name="action_promote" type="object" string="Promote"
                                invisible="state != 'enrolled'" class="btn-success"/>
                        <button name="action_withdraw" type="object" string="Withdraw"
                                invisible="state not in ('draft','enrolled')" class="btn-danger"/>
                        <button name="action_send_whatsapp" type="object"
                                string="📱 Send WhatsApp" class="btn-warning"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,enrolled,promoted,alumni"/>
                    </header>
                    <sheet>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <div class="oe_title">
                            <label class="o_field_widget" for="name"/>
                            <h1><field name="name" placeholder="Student Full Name"/></h1>
                            <div class="o_row">
                                <span class="me-2">
                                    Roll No: <strong><field name="roll_number" readonly="1"/></strong>
                                </span>
                                <span class="me-2">
                                    Adm No: <strong><field name="admission_number" readonly="1"/></strong>
                                </span>
                                <span>
                                    GR No: <strong><field name="gr_number" readonly="1"/></strong>
                                </span>
                            </div>
                        </div>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_fees" type="object"
                                    class="oe_stat_button" icon="fa-money">
                                <field name="fee_count" widget="statinfo" string="Fee Invoices"/>
                            </button>
                            <button name="action_view_ledger" type="object"
                                    class="oe_stat_button" icon="fa-book">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Ledger</span>
                                </div>
                            </button>
                        </div>
                        <notebook>
                            <page string="Basic Info" name="basic">
                                <group>
                                    <group string="Personal Details">
                                        <field name="gender"/>
                                        <field name="date_of_birth"/>
                                        <field name="age"/>
                                        <field name="blood_group"/>
                                        <field name="religion"/>
                                        <field name="nationality"/>
                                        <field name="cnic_b_form"/>
                                    </group>
                                    <group string="Academic Details">
                                        <field name="class_id"/>
                                        <field name="section_id"/>
                                        <field name="academic_year"/>
                                        <field name="admission_date"/>
                                        <field name="previous_school"/>
                                        <field name="previous_class"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Contact" name="contact">
                                <group>
                                    <group string="Student Contact">
                                        <field name="phone"/>
                                        <field name="mobile"/>
                                        <field name="email" widget="email"/>
                                        <field name="address"/>
                                        <field name="city"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Guardian Info" name="guardian">
                                <group>
                                    <group string="Father">
                                        <field name="father_name"/>
                                        <field name="father_cnic"/>
                                        <field name="father_occupation"/>
                                        <field name="father_phone"/>
                                        <field name="father_mobile"/>
                                        <field name="father_email"/>
                                    </group>
                                    <group string="Mother">
                                        <field name="mother_name"/>
                                        <field name="mother_cnic"/>
                                        <field name="mother_phone"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Guardian (if different)">
                                        <field name="guardian_name"/>
                                        <field name="guardian_relation"/>
                                        <field name="guardian_phone"/>
                                        <field name="guardian_cnic"/>
                                        <field name="guardian_whatsapp"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Fee Info" name="fee">
                                <group>
                                    <group>
                                        <field name="fee_structure_id"/>
                                        <field name="concession_type"/>
                                        <field name="concession_value"
                                               invisible="concession_type == 'none'"/>
                                        <field name="concession_reason"
                                               invisible="concession_type == 'none'"/>
                                    </group>
                                    <group>
                                        <field name="outstanding_balance"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Additional" name="additional">
                                <group>
                                    <group>
                                        <field name="transport_route"/>
                                        <field name="hostel"/>
                                        <field name="medical_condition"/>
                                    </group>
                                    <group invisible="state not in ('withdrawn','transferred','alumni')">
                                        <field name="leaving_date"/>
                                        <field name="leaving_reason"/>
                                        <field name="leaving_certificate"/>
                                    </group>
                                </group>
                                <field name="notes" placeholder="Additional notes..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Student List -->
        <record id="view_school_student_list" model="ir.ui.view">
            <field name="name">school.student.list</field>
            <field name="model">school.student</field>
            <field name="arch" type="xml">
                <list string="Students"
                      decoration-warning="state == 'promoted'"
                      decoration-muted="state in ('withdrawn','transferred')"
                      decoration-success="state == 'enrolled'">
                    <field name="roll_number" optional="show"/>
                    <field name="admission_number" optional="show"/>
                    <field name="image" widget="image" optional="show" class="o_image_24_cover"/>
                    <field name="name"/>
                    <field name="father_name"/>
                    <field name="class_id"/>
                    <field name="section_id"/>
                    <field name="gender"/>
                    <field name="mobile"/>
                    <field name="guardian_whatsapp" optional="hide"/>
                    <field name="admission_date" optional="hide"/>
                    <field name="outstanding_balance" optional="show"/>
                    <field name="state" widget="badge"
                           decoration-success="state == 'enrolled'"
                           decoration-warning="state == 'promoted'"
                           decoration-danger="state == 'withdrawn'"/>
                </list>
            </field>
        </record>

        <!-- Student Kanban -->
        <record id="view_school_student_kanban" model="ir.ui.view">
            <field name="name">school.student.kanban</field>
            <field name="model">school.student</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" default_group_by="class_id">
                    <field name="name"/>
                    <field name="image"/>
                    <field name="roll_number"/>
                    <field name="father_name"/>
                    <field name="mobile"/>
                    <field name="state"/>
                    <field name="class_id"/>
                    <field name="section_id"/>
                    <field name="outstanding_balance"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click d-flex align-items-start p-2">
                                <img t-att-src="kanban_image('school.student', 'image', record.id.raw_value)"
                                     class="rounded-circle me-3 flex-shrink-0"
                                     style="width:52px;height:52px;object-fit:cover;" alt="Photo"/>
                                <div class="flex-grow-1">
                                    <strong class="d-block"><field name="name"/></strong>
                                    <span class="text-muted">Roll: <field name="roll_number"/></span><br/>
                                    <span class="text-muted">Father: <field name="father_name"/></span><br/>
                                    <t t-if="record.outstanding_balance.raw_value > 0">
                                        <span class="badge bg-danger">Balance: <field name="outstanding_balance"/></span>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Student Search -->
        <record id="view_school_student_search" model="ir.ui.view">
            <field name="name">school.student.search</field>
            <field name="model">school.student</field>
            <field name="arch" type="xml">
                <search string="Search Students">
                    <field name="name"/>
                    <field name="roll_number"/>
                    <field name="admission_number"/>
                    <field name="gr_number"/>
                    <field name="father_name"/>
                    <field name="mobile"/>
                    <field name="guardian_whatsapp"/>
                    <field name="class_id"/>
                    <field name="section_id"/>
                    <filter string="Enrolled" name="enrolled" domain="[('state','=','enrolled')]"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Withdrawn" name="withdrawn" domain="[('state','=','withdrawn')]"/>
                    <filter string="With Outstanding" name="outstanding" domain="[('outstanding_balance','>',0)]"/>
                    <filter string="Class" name="by_class" context="{'group_by':'class_id'}"/>
                    <filter string="Section" name="by_section" context="{'group_by':'section_id'}"/>
                    <filter string="Gender" name="by_gender" context="{'group_by':'gender'}"/>
                    <filter string="Status" name="by_state" context="{'group_by':'state'}"/>
                </search>
            </field>
        </record>

        <!-- Student Action -->
        <record id="action_school_student" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">school.student</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="search_view_id" ref="view_school_student_search"/>
            <field name="context">{'search_default_enrolled': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Admit your first student!
                </p>
            </field>
        </record>

        <!-- New Admission Action -->
        <record id="action_school_student_new" model="ir.actions.act_window">
            <field name="name">New Admission</field>
            <field name="res_model">school.student</field>
            <field name="view_mode">form</field>
            <field name="context">{'default_state': 'draft'}</field>
        </record>
    </data>
</odoo>
