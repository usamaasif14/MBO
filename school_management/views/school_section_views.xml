<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_school_section_list" model="ir.ui.view">
            <field name="name">school.section.list</field>
            <field name="model">school.section</field>
            <field name="arch" type="xml">
                <list string="Sections">
                    <field name="class_id"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="teacher_id"/>
                    <field name="capacity"/>
                    <field name="room_number"/>
                    <field name="student_count" string="Students"/>
                </list>
            </field>
        </record>

        <record id="view_school_section_form" model="ir.ui.view">
            <field name="name">school.section.form</field>
            <field name="model">school.section</field>
            <field name="arch" type="xml">
                <form string="Section">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_students" type="object"
                                    class="oe_stat_button" icon="fa-users">
                                <field name="student_count" widget="statinfo" string="Students"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="class_id"/>
                                <field name="name"/>
                                <field name="code"/>
                            </group>
                            <group>
                                <field name="teacher_id"/>
                                <field name="capacity"/>
                                <field name="room_number"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_school_section" model="ir.actions.act_window">
            <field name="name">Sections</field>
            <field name="res_model">school.section</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
