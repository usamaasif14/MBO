<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_school_homework_list" model="ir.ui.view">
            <field name="name">school.homework.list</field>
            <field name="model">school.homework</field>
            <field name="arch" type="xml">
                <list string="Homework" decoration-info="state == 'draft'">
                    <field name="name"/>
                    <field name="class_id"/>
                    <field name="subject_id"/>
                    <field name="date"/>
                    <field name="due_date"/>
                    <field name="teacher_id"/>
                    <field name="state" widget="badge"/>
                </list>
            </field>
        </record>

        <record id="view_school_homework_form" model="ir.ui.view">
            <field name="name">school.homework.form</field>
            <field name="model">school.homework</field>
            <field name="arch" type="xml">
                <form string="Homework">
                    <header>
                        <button name="action_assign" type="object" string="Assign" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_send_whatsapp" type="object" string="Send via WhatsApp" class="btn-warning"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Homework Title"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="class_id"/>
                                <field name="section_id"/>
                                <field name="subject_id"/>
                                <field name="teacher_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="due_date"/>
                                <field name="priority"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Instructions">
                                <field name="description"/>
                            </page>
                            <page string="Attachments">
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_school_homework" model="ir.actions.act_window">
            <field name="name">Homework</field>
            <field name="res_model">school.homework</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
