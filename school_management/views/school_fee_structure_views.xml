<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Fee Type List -->
        <record id="view_school_fee_type_list" model="ir.ui.view">
            <field name="name">school.fee.type.list</field>
            <field name="model">school.fee.type</field>
            <field name="arch" type="xml">
                <list string="Fee Types" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="billing_type"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="action_school_fee_type" model="ir.actions.act_window">
            <field name="name">Fee Types</field>
            <field name="res_model">school.fee.type</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Fee Structure List -->
        <record id="view_school_fee_structure_list" model="ir.ui.view">
            <field name="name">school.fee.structure.list</field>
            <field name="model">school.fee.structure</field>
            <field name="arch" type="xml">
                <list string="Fee Structures">
                    <field name="name"/>
                    <field name="class_id"/>
                    <field name="academic_year"/>
                    <field name="total_monthly"/>
                    <field name="total_annual"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Fee Structure Form -->
        <record id="view_school_fee_structure_form" model="ir.ui.view">
            <field name="name">school.fee.structure.form</field>
            <field name="model">school.fee.structure</field>
            <field name="arch" type="xml">
                <form string="Fee Structure">
                    <header>
                        <button name="action_print_fee_structure" type="object"
                                string="Print Fee Structure" class="btn-secondary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Fee Structure Name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="class_id"/>
                                <field name="academic_year"/>
                                <field name="active"/>
                            </group>
                            <group>
                                <field name="total_monthly" readonly="1"/>
                                <field name="total_annual" readonly="1"/>
                            </group>
                        </group>
                        <field name="fee_line_ids">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="fee_type_id"/>
                                <field name="name"/>
                                <field name="fee_type" readonly="1" optional="show"/>
                                <field name="amount"/>
                                <field name="optional"/>
                                <field name="notes"/>
                            </list>
                        </field>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_school_fee_structure" model="ir.actions.act_window">
            <field name="name">Fee Structure</field>
            <field name="res_model">school.fee.structure</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
