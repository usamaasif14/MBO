<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_school_whatsapp_config_form" model="ir.ui.view">
            <field name="name">school.whatsapp.config.form</field>
            <field name="model">school.whatsapp.config</field>
            <field name="arch" type="xml">
                <form string="WhatsApp Configuration">
                    <sheet>
                        <widget name="web_ribbon" title="Active" bg_color="bg-success" invisible="not active"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="API Settings">
                                <field name="provider"/>
                                <field name="api_url" invisible="provider not in ('ultramsg', 'wa_gateway')"/>
                                <field name="instance_id" invisible="provider != 'ultramsg'"/>
                                <field name="api_token" invisible="provider == 'twilio'"/>
                                <field name="account_sid" invisible="provider != 'twilio'"/>
                                <field name="auth_token" invisible="provider != 'twilio'" password="True"/>
                                <field name="from_number" invisible="provider != 'twilio'"/>
                                <field name="active"/>
                            </group>
                            <group string="School Info (For Templates)">
                                <field name="school_name"/>
                                <field name="school_phone"/>
                                <field name="school_address"/>
                                <field name="school_logo" widget="image" class="oe_avatar"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_school_whatsapp_config" model="ir.actions.act_window">
            <field name="name">WhatsApp Configuration</field>
            <field name="res_model">school.whatsapp.config</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_school_whatsapp_log_list" model="ir.ui.view">
            <field name="name">school.whatsapp.log.list</field>
            <field name="model">school.whatsapp.log</field>
            <field name="arch" type="xml">
                <list string="WhatsApp Logs" create="0" edit="0">
                    <field name="date"/>
                    <field name="name"/>
                    <field name="student_id"/>
                    <field name="mobile"/>
                    <field name="message_type"/>
                    <field name="state" widget="badge" decoration-danger="state == 'failed'" decoration-success="state == 'sent'"/>
                    <field name="error_message" optional="show"/>
                </list>
            </field>
        </record>

        <record id="action_school_whatsapp_log" model="ir.actions.act_window">
            <field name="name">WhatsApp Logs</field>
            <field name="res_model">school.whatsapp.log</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>
