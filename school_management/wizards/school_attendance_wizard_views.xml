<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_school_attendance_wizard_standalone_form" model="ir.ui.view">
            <field name="name">school.attendance.wizard.standalone.form</field>
            <field name="model">school.attendance.wizard.standalone</field>
            <field name="arch" type="xml">
                <form string="Attendance Report">
                    <group>
                        <field name="class_id"/>
                        <field name="date"/>
                    </group>
                    <footer>
                        <button string="Generate" class="btn-primary" special="cancel"/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_school_attendance_wizard_standalone" model="ir.actions.act_window">
            <field name="name">Attendance Report</field>
            <field name="res_model">school.attendance.wizard.standalone</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
