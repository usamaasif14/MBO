<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_school_whatsapp_wizard_form" model="ir.ui.view">
            <field name="name">school.whatsapp.wizard.form</field>
            <field name="model">school.whatsapp.wizard</field>
            <field name="arch" type="xml">
                <form string="Send WhatsApp Message">
                    <group>
                        <group>
                            <field name="send_to" widget="radio"/>
                            <field name="class_id" invisible="send_to != 'class'" required="send_to == 'class'"/>
                            <field name="section_id" invisible="send_to != 'class'"/>
                            <field name="mobile" invisible="send_to != 'students'"/>
                            <field name="student_ids" widget="many2many_tags" invisible="send_to != 'students'"/>
                        </group>
                        <group>
                            <field name="config_id" required="1"/>
                            <field name="use_template"/>
                            <field name="template_type" invisible="not use_template"/>
                            <field name="type"/>
                        </group>
                    </group>
                    <group>
                        <field name="message" placeholder="Type your message here..."/>
                    </group>
                    <footer>
                        <button name="action_send" type="object" string="Send Message" class="btn-primary" icon="fa-paper-plane"/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_school_whatsapp_wizard" model="ir.actions.act_window">
            <field name="name">Send WhatsApp Message</field>
            <field name="res_model">school.whatsapp.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
