<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_school_fee_payment_wizard_form" model="ir.ui.view">
            <field name="name">school.fee.payment.wizard.form</field>
            <field name="model">school.fee.payment.wizard</field>
            <field name="arch" type="xml">
                <form string="Register Payment">
                    <group>
                        <group>
                            <field name="invoice_id" readonly="1"/>
                            <field name="student_id" readonly="1"/>
                            <field name="amount_due" readonly="1"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="payment_method"/>
                            <field name="payment_date"/>
                            <field name="bank_reference" invisible="payment_method == 'cash'"/>
                            <field name="collected_by"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Remarks"/>
                        <field name="print_receipt"/>
                    </group>
                    <footer>
                        <button name="action_confirm_payment" type="object" string="Confirm Payment" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_school_generate_fee_wizard_form" model="ir.ui.view">
            <field name="name">school.generate.fee.wizard.form</field>
            <field name="model">school.generate.fee.wizard</field>
            <field name="arch" type="xml">
                <form string="Generate Monthly Fee">
                    <group>
                        <group>
                            <field name="class_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="fee_month"/>
                            <field name="fee_year"/>
                        </group>
                        <group>
                            <field name="invoice_date"/>
                            <field name="due_date"/>
                            <field name="check_duplicate"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate" type="object" string="Generate Fees" class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
